{
  "rules": {
    ".read": false,
    ".write": false,
    "socialChatRooms": {
      "$roomId": {
        "$msgId": { ".read": true, ".write": true }
      }
    },
    "signals": {
      "$roomId": {
        "$signalId": { ".read": true, ".write": true }
      }
    },
    "messages": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    }
  }
}
