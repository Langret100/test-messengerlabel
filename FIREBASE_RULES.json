{
  "rules": {
    ".read": false,
    ".write": false,
    "socialChatRooms": {
      "$roomId": { "$msgId": { ".read": true, ".write": true } }
    },
    "signals": {
      "$roomId": { "$signalId": { ".read": true, ".write": true } }
    },
    "messages": {
      "$roomId": {
        ".read": true,
        ".write": true,
        ".indexOn": ["ts"]
      }
    },
    "profiles": {
      "$nickname": { ".read": true, ".write": true }
    },
    "rooms": {
      "$roomId": { ".read": true, ".write": true }
    },
    "fcm_tokens": {
      "$userId": { ".read": true, ".write": true }
    },
    "fcm_active_room": {
      "$userId": { ".read": true, ".write": true }
    }
  }
}
